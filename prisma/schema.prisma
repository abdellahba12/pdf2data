generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  password          String?
  googleId          String?    @unique
  emailVerified     Boolean    @default(false)
  verifyToken       String?
  createdAt         DateTime   @default(now())
  plan              String     @default("free")
  trialEndsAt       DateTime?
  stripeCustomerId  String?
  stripeSubId       String?
  docsThisMonth     Int        @default(0)
  docsResetAt       DateTime   @default(now())
  totalDocsUsed     Int        @default(0)
  companyName       String?
  companyCIF        String?
  companyAddress    String?
  companyPhone      String?
  companyEmail      String?
  companyIBAN       String?
  companyLogoUrl    String?
  companyStyle      Json?
  templateFileUrl   String?
  invoiceCounter    Int        @default(0)
  invoiceSeries     String     @default("FAC")
  documents         Document[]
  clients           Client[]
}

model Client {
  id        String     @id @default(uuid())
  userId    String
  name      String
  cif       String?
  address   String?
  email     String?
  phone     String?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])
  documents Document[]
}

model Document {
  id              String    @id @default(uuid())
  userId          String
  clientId        String?
  fileName        String
  fileUrl         String
  status          String    @default("processing")
  invoiceStatus   String    @default("draft")
  invoiceNumber   String?
  extractedData   Json?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  client          Client?   @relation(fields: [clientId], references: [id])
}
